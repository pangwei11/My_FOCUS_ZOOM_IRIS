// &mdio {
// 	rmii_phy: ethernet-phy@2 {
// 		compatible = "ethernet-phy-id0680.8101", "ethernet-phy-ieee802.3-c22";
// 		reg = <2>;
// 		clocks = <&cru CLK_MACPHY>;
// 		clock-frequency = <50000000>;
